{
  "name": "gooblin-hooks",
  "version": "1.0.0",
  "description": "Reminder-only lifecycle hooks for Gooblin mode. Supports GOOBLIN_DISABLE and GOOBLIN_HOOK_MODE.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/gooblin-activate.js\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/gooblin-mode-tracker.js\""
          }
        ]
      }
    ]
  },
  "safety": {
    "network": false,
    "telemetry": false,
    "mutates_user_files": false,
    "dangerous_commands": false
  }
}
